# =============================================================================
# SkyN3t Configuration Template
# Copy this file to .env and fill in your actual values.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME=SkyN3t
APP_ENV=development
LOG_LEVEL=INFO
DEBUG=false

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
HOST=0.0.0.0
PORT=6660
RELOAD=false

# Web dashboard/API authentication.
# By default the control plane requires SKYN3T_WEB_TOKEN. Set it to a long
# random string and use ?token=... or Authorization: Bearer ... to authenticate.
# For trusted local-only development you may opt in to loopback-only mode:
#   SKYN3T_ALLOW_UNAUTHENTICATED_LOOPBACK=1
# Do NOT use the loopback mode if the host is shared or the dashboard is exposed.
# SKYN3T_WEB_TOKEN=change-me-to-a-long-random-string
# SKYN3T_ALLOW_UNAUTHENTICATED_LOOPBACK=1
# SKYN3T_ALLOW_EXEC_API=0          # set 1 to enable POST /api/exec on trusted dev hosts

# -----------------------------------------------------------------------------
# Paths
# -----------------------------------------------------------------------------
# Store Studio projects/artifacts outside the repo if you prefer.
PROJECTS_DIR=~/Documents/Skyn3t/Projects

# -----------------------------------------------------------------------------
# LLM Backend Selection
# SKYN3T_LLM_BACKEND defaults to "auto", which prefers SUBSCRIPTION-backed
# local CLIs (claude, kimi, ...) over metered API keys. This means users on
# Claude Pro/Max or Kimi/Copilot subscriptions are not billed against an API
# key just because one happens to be set.
#
# Resolution order in auto mode:
#   1. `claude` CLI  (Anthropic Pro/Max subscription) — if on PATH
#   2. `kimi`   CLI  (Kimi subscription)              — if on PATH
#   3. ANTHROPIC_API_KEY  (metered)                   — if set
#   4. OPENROUTER_API_KEY (metered)                   — if set
#   5. deterministic stub (offline fallback)
#
# Force a specific backend with one of:
#   claude_cli | kimi_cli | copilot_cli | openai_cli
#   anthropic  | openrouter | deterministic
# -----------------------------------------------------------------------------
SKYN3T_LLM_BACKEND=auto
SKYN3T_LLM_MODEL=

# Run `skyn3t wizard` for guided multi-LLM setup (Studio Quality OpenRouter preset recommended).

# Studio quality (defaults favor shipping runnable software over speed)
# SKYN3T_AUTO_RETRY=1          # one bounded retry when a build fails (set 0 to disable)
# SKYN3T_DISABLE_CRITIQUE=0    # set 1 to skip inter-agent critique loops
# SKYN3T_VERIFY_OFFLINE=0      # set 1 to accept syntax-only pass when npm install has no network
# SKYN3T_VERIFY_NPM_INSTALL=1  # set 0 to skip npm install/build in BuildVerifier
# SKYN3T_CODE_TIER=or_backend  # downgrade code stage from or_strong (or_cheap for max savings)
# SKYN3T_CHEAP_SMART=1         # cheap-first code gen + context boost + smart escalation (default on; set 0 to disable)
# SKYN3T_STUDIO_TOKEN_BUDGET=500000  # per-project estimated token cap (0=disabled); Forge-style cost guard
# SKYN3T_CORTEX_SCOUT_COMPETITIVE=1  # merge competitor-targeted scout queries (default on)
# CodeAgent Python sandbox: auto|inline|docker|docker-pool
# SECURITY: "inline" runs code in-process via exec() and is disabled by default.
# Set SKYN3T_ALLOW_INLINE_EXEC=1 to opt in to trusted-only in-process execution.
# SKYN3T_EXECUTION_BACKEND=auto
# SKYN3T_ALLOW_INLINE_EXEC=1

# Docker sandbox hardening (default on). Disable only if a workload genuinely
# breaks with the stricter flags.
# SKYN3T_DOCKER_HARDENING=1
# SKYN3T_DOCKER_USER=65534:65534
# SKYN3T_DOCKER_CAP_DROP_ALL=1
# SKYN3T_DOCKER_NO_NEW_PRIVS=1
# SKYN3T_DOCKER_CPUS=1.0
# SKYN3T_DOCKER_PIDS_LIMIT=64
# SKYN3T_DOCKER_POOL_RECYCLE_AFTER=50

# SKYN3T_AUTO_RETRY=1          # set by skyn3t wizard Studio Quality preset

# -----------------------------------------------------------------------------
# LLM API Keys (OPTIONAL)
# Only used if no subscription CLI is available, or if you explicitly select
# an api-backed backend via SKYN3T_LLM_BACKEND. Leave blank to rely on local
# CLI subscriptions.
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
OPENROUTER_API_KEY=

# Auto-sync OpenRouter model catalog on startup (default on when OPENROUTER_API_KEY is set).
# Cached at data/openrouter_models.json (24h TTL; 6h when evolution enabled).
# Manual refresh: skyn3t models sync [--force] [--evolve]
# SKYN3T_OPENROUTER_SYNC=1

# Proactive model evolution — score OpenRouter catalog and upgrade tier assignments.
# Default ON when OPENROUTER_API_KEY is set. Persists to data/model_tier_overrides.json.
# SKYN3T_MODEL_EVOLUTION=1
# SKYN3T_MODEL_EVOLUTION=0          # disable auto tier upgrades
# SKYN3T_MODEL_EVOLUTION_DOWNGRADE=0  # never downgrade tiers (default)
# SKYN3T_MODEL_EVOLUTION_MIN_GAIN=0.25  # minimum score delta to replace a tier model

KIMI_API_KEY=...
COPILOT_API_KEY=...

# -----------------------------------------------------------------------------
# RAG (Retrieval-Augmented Generation)
# -----------------------------------------------------------------------------
RAG_VECTOR_STORE_PATH=./data/vector_store
RAG_EMBEDDING_MODEL=text-embedding-3-small
RAG_TOP_K=5

# -----------------------------------------------------------------------------
# GitHub
# -----------------------------------------------------------------------------
GITHUB_TOKEN=ghp_...

# -----------------------------------------------------------------------------
# Scheduler
# -----------------------------------------------------------------------------
SCHEDULER_DB_PATH=./data/scheduler.db

# -----------------------------------------------------------------------------
# Daemon
# -----------------------------------------------------------------------------
HEALTH_CHECK_INTERVAL=30

# -----------------------------------------------------------------------------
# Cortex / proposals
# -----------------------------------------------------------------------------
# No-approval mode — skip Studio architect/designer gates; auto-triage Cortex ingest/tuning
# SKYN3T_NO_APPROVAL=1             # explicit (synonyms: SKYN3T_AUTO_APPROVE=1, SKYN3T_AUTO_APPROVE_STUDIO=1)
# SKYN3T_AUTONOMOUS_BUILDS=1       # also enables no-approval unless SKYN3T_AUTO_APPROVE=0
# SKYN3T_AUTONOMOUS_LEARNING=1     # scout + learning loops (default on)
# SKYN3T_AUTONOMOUS_BUILD_DAILY_CAP=3
# SKYN3T_AUTONOMOUS_BUILD_INTERVAL_SECONDS=900
# SKYN3T_CORTEX_AUTO_APPROVE_SCOUT_INGEST=true
# SKYN3T_CORTEX_AUTO_APPROVE_SAFE_TUNING=true
# SKYN3T_CORTEX_AUTO_APPROVE_BUILD_PATTERN_BIAS=true
# SKYN3T_CORTEX_SCOUT_SPAWN_FEATURES=true
# SKYN3T_CORTEX_SCOUT_SPAWN_MIN_INGESTED=1
# SKYN3T_CORTEX_SCOUT_SKIP_WHEN_BUSY=true
# SKYN3T_CORTEX_SCOUT_RUN_TIMEOUT_SECONDS=300
# Server-side discovery queries (scout UI is automatic — no search box):
# SKYN3T_CORTEX_SCOUT_FIT_QUERIES=multi agent orchestrator cli memory rag,cortex autonomy self-healing
# SKYN3T_CORTEX_SCOUT_DEFAULT_LIMIT=2

# -----------------------------------------------------------------------------
# Autonomous loops (MISSION: learn + build without manual prompts)
# -----------------------------------------------------------------------------
# SKYN3T_AUTONOMOUS_LEARNING=1       # scout cron + ingest on orchestrator start (default on)
# SKYN3T_AUTONOMOUS_BUILDS=0         # auto-start Studio builds (default off — set 1 to enable)
# SKYN3T_NO_APPROVAL=1               # skip architect/designer gates (implicit when BUILDS=1)
# SKYN3T_AUTONOMOUS_BUILD_DAILY_CAP=3
# SKYN3T_AUTONOMOUS_BUILD_DAILY_BUDGET_USD=5.0
# SKYN3T_AUTONOMOUS_BUILD_INTERVAL_SECONDS=900

# -----------------------------------------------------------------------------
# Parallel agent fleet (20 concurrent learn + build workers)
# -----------------------------------------------------------------------------
# SKYN3T_AGENT_FLEET_SIZE=20              # max parallel autonomous Studio builds
# SKYN3T_AGENT_FLEET_MAX_CONCURRENT_BUILDS=5  # Studio semaphore cap (keeps API responsive at fleet=20)
# SKYN3T_AGENT_FLEET_LEARNING=1           # parallel scout/RAG/routing/evolution workers
# SKYN3T_CORTEX_SCOUT_DEFER_BOOT_SECONDS=120  # skip fleet scout GitHub searches during boot
# SKYN3T_STUDIO_WORKTREE=1                # git worktree per fleet slot for CodeAgent (default on for fleet)
# SKYN3T_CONTINUOUS_IMPROVEMENT=1         # also boots 3-slot fleet when FLEET_SIZE unset
# When fleet enabled, raise caps for throughput:
# SKYN3T_AUTONOMOUS_BUILD_DAILY_CAP=20
# SKYN3T_AUTONOMOUS_BUILD_INTERVAL_SECONDS=60
# SKYN3T_AUTONOMOUS_SCOUT_SCHEDULE=interval:12h
# SKYN3T_AUTONOMOUS_PROOF_RUN=1         # post-build npm/py_compile proof for auto builds (default on)
# SKYN3T_SKILLS_HUB_AUTO_INSTALL=1      # seed examples/skills_seed when no-approval (default on)
# SKYN3T_SKILLS_HUB_PATHS=examples/skills_seed,skills
# SKYN3T_ROUTER_ADAPTIVE=1           # auto-apply routing demotions from build scoreboard (default on)

# -----------------------------------------------------------------------------
# Never-stop improvement flywheel (default on)
# -----------------------------------------------------------------------------
# SKYN3T_CONTINUOUS_IMPROVEMENT=1    # background flywheel on orchestrator boot (default on)
# SKYN3T_NEVER_STOP=1                # watchdog restarts dead autonomy tasks (default on with improvement)
# SKYN3T_NEVER_STOP_QUEUE_EMPTY_SECONDS=300  # inject synthetic briefs when queue empty this long
# SKYN3T_IMPROVEMENT_TICK_SECONDS=600
# SKYN3T_IMPROVEMENT_SCORE_REGRESSION=70   # rolling reviewer avg threshold per stack
# SKYN3T_IMPROVEMENT_SCORE_WINDOW=8
# SKYN3T_IMPROVEMENT_COMPETITIVE_PRACTICE_DAILY_CAP=1
# SKYN3T_IMPROVEMENT_PROOF_RETRY_DAILY_CAP=2
# SKYN3T_MODEL_EVOLUTION=1           # proactive OpenRouter tier upgrades (default on with API key)
# Process wrapper (optional, outside Python): ./scripts/never_stop.sh  # restarts web if port dies

# -----------------------------------------------------------------------------
# Crash recovery
# -----------------------------------------------------------------------------
# SKYN3T_AUTONOMOUS_BUILD_MAX_RETRIES=3   # drop a brief after this many failed starts
# SKYN3T_AUTONOMOUS_QUEUE_MAX_DEPTH=100    # cap autonomous brief queue depth
# SKYN3T_AUTONOMOUS_RESUME_INTERRUPTED=1  # resume Studio projects marked interrupted on boot

# -----------------------------------------------------------------------------
# Consciousness snapshots — durable orchestrator state
# -----------------------------------------------------------------------------
# SKYN3T_SNAPSHOT_ENABLED=1               # periodic + shutdown snapshots (default on)
# SKYN3T_SNAPSHOT_INTERVAL_SECONDS=300    # seconds between periodic snapshots
# SKYN3T_SNAPSHOT_MAX_KEPT=10             # rotation count for data/checkpoints
# SKYN3T_RESTORE_ON_BOOT=1                # restore latest snapshot on orchestrator start
# SKYN3T_SNAPSHOT_DIR=./data/checkpoints  # snapshot storage directory

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
SECRET_KEY=
SKYN3T_MASTER_KEY=
SECURITY_ENABLED=true
ENVIRONMENT=development
